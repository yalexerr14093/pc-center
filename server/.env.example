# Скопируется в .env командой: npm run bootstrap
PORT=4000
DATABASE_URL="postgresql://postgres:ВАШ_ПАРОЛЬ@localhost:5432/pc_center?schema=public"
JWT_SECRET="pc-center-dev-secret-min-16-chars"

# Необязательно: CORS (через запятую, если порт Vite другой)
CLIENT_ORIGIN="http://localhost:5173"

# Необязательно: Stripe test key для оплаты
# STRIPE_SECRET_KEY="sk_test_..."

# Необязательно: админ при npm run db:seed
# ADMIN_EMAIL="admin@pc-center.local"
# ADMIN_PASSWORD="adminadmin"
